#include <LPC214X.h>
void delay (unsigned int);
int main ()
{
PINSEL0=0X00000000;
IODIR0=IODIR0|(0X01<<4);
IODIR0=IODIR0|(0X01<<5);
IODIR0=IODIR0|(0X01<<6);
IODIR0=IODIR0|(0X01<<7);
while(1)
{
IOSET0=IOSET0|(0X01<<4);
delay(1000);
IOCLR0=IOCLR0|(0X01<<4);
IOSET0=IOSET0|(0X01<<5);
delay(1000);
IOCLR0=IOCLR0|(0X01<<5);
IOSET0=IOSET0|(0X01<<6);
delay(1000);
IOCLR0=IOCLR0|(0X01<<6);
IOSET0=IOSET0|(0X01<<7);
delay(1000);
IOCLR0=IOCLR0|(0X01<<7);
}
}
void delay (unsigned int dly)
{
unsigned int i,j;
for (i=0;i<dly;i++)
{
for (j=0;j<100;j++);
}
}
